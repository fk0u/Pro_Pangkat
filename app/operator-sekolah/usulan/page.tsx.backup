export default function OperatorSekolahUsulanPage() {
  const [usulanData, setUsulanData] = useState<Usulan[]>([])
  const [filteredData, setFilteredData] = useState<Usulan[]>([])
  const [loading, setLoading] = useState(true)
  const [searchQuery, setSearchQuery] = useState("")
  const [statusFilter, setStatusFilter] = useState("all")
  
  // Modal states
  const [isAddModalOpen, setIsAddModalOpen] = useState(false)
  const [isViewModalOpen, setIsViewModalOpen] = useState(false)
  const [isEditModalOpen, setIsEditModalOpen] = useState(false)
  const [selectedUsulan, setSelectedUsulan] = useState<Usulan | null>(null)
  const [pegawaiOptions, setPegawaiOptions] = useState<PegawaiOption[]>([])
  const [loadingPegawai, setLoadingPegawai] = useState(false)
  const [submitting, setSubmitting] = useState(false)
  const [exporting, setExporting] = useState(false)
  const [usulanDetails, setUsulanDetails] = useState<UsulanDetails | null>(null)
  const [loadingDetails, setLoadingDetails] = useState(false)
  
  // Form states
  const [formData, setFormData] = useState({
    pegawaiId: "",
    periode: new Date().getFullYear().toString(),
    keterangan: "",
    nomorSuratPengantar: "",
    tanggalSurat: "",
    fileSuratPengantar: null as File | null
  })
  
  const { toast } = useToast()

  // Reset form
  const resetForm = () => {
    setFormData({
      pegawaiId: "",
      periode: new Date().getFullYear().toString(),
      keterangan: "",
      nomorSuratPengantar: "",
      tanggalSurat: "",
      fileSuratPengantar: null
    })
  }

  // Load pegawai options for dropdown
  const loadPegawaiOptions = async () => {
    try {
      setLoadingPegawai(true)
      const response = await fetch('/api/operator-sekolah/pegawai?limit=100')
      
      if (response.ok) {
        const result = await response.json()
        const mapped = (result.data || []).map((item: ApiPegawaiResponse) => ({
          id: item.id,
          nip: item.nip,
          nama: item.name,
          jabatan: item.jabatan || '',
          golongan: item.golongan || '',
          unitKerja: item.unitKerja || ''
        }))
        setPegawaiOptions(mapped)
      }
    } catch (error) {
      console.error('Error loading pegawai:', error)
      toast({
        title: "Error",
        description: "Gagal memuat data pegawai",
        variant: "destructive"
      })
    } finally {
      setLoadingPegawai(false)
    }
  }

  // Handle add usulan
  const handleAddUsulan = async () => {
    try {
      setSubmitting(true)
      
      // Validation
      if (!formData.pegawaiId) {
        toast({
          title: "Error",
          description: "Pilih pegawai terlebih dahulu",
          variant: "destructive"
        })
        return
      }
      
      if (!formData.nomorSuratPengantar.trim()) {
        toast({
          title: "Error",
          description: "Nomor surat pengantar wajib diisi",
          variant: "destructive"
        })
        return
      }
      
      if (!formData.tanggalSurat) {
        toast({
          title: "Error",
          description: "Tanggal surat wajib diisi",
          variant: "destructive"
        })
        return
      }
      
      // Create FormData for file upload
      const submitData = new FormData()
      submitData.append('pegawaiId', formData.pegawaiId)
      submitData.append('periode', formData.periode)
      submitData.append('keterangan', formData.keterangan || '')
      submitData.append('nomorSuratPengantar', formData.nomorSuratPengantar)
      submitData.append('tanggalSurat', formData.tanggalSurat)
      
      if (formData.fileSuratPengantar) {
        submitData.append('fileSuratPengantar', formData.fileSuratPengantar)
      }
      
      const response = await fetch('/api/operator-sekolah/usulan', {
        method: 'POST',
        body: submitData
      })

      if (response.ok) {
        toast({
          title: "Berhasil!",
          description: "Usulan berhasil dibuat",
        })
        setIsAddModalOpen(false)
        resetForm()
        fetchData() // Reload data
      } else {
        const errorData = await response.json()
        throw new Error(errorData.message || 'Failed to create usulan')
      }
    } catch (error) {
      console.error('Error adding usulan:', error)
      toast({
        title: "Error",
        description: error instanceof Error ? error.message : "Gagal membuat usulan",
        variant: "destructive"
      })
    } finally {
      setSubmitting(false)
    }
  }

  // Export to Excel
  const exportToExcel = async () => {
    try {
      setExporting(true)
      
      const params = new URLSearchParams({
        format: 'excel',
        ...(statusFilter !== "all" && { status: statusFilter })
      })
      
      const response = await fetch(`/api/operator-sekolah/usulan/export?${params}`)
      
      if (response.ok) {
        const blob = await response.blob()
        const url = window.URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = `usulan-kenaikan-pangkat-${new Date().toISOString().split('T')[0]}.xlsx`
        document.body.appendChild(a)
        a.click()
        document.body.removeChild(a)
        window.URL.revokeObjectURL(url)
        
        toast({
          title: "Berhasil",
          description: "File Excel berhasil diunduh",
        })
      } else {
        throw new Error('Export failed')
      }
    } catch (error) {
      console.error('Error exporting to Excel:', error)
      toast({
        title: "Error",
        description: "Gagal mengunduh file Excel",
        variant: "destructive"
      })
    } finally {
      setExporting(false)
    }
  }

  // Handle view usulan
  const handleViewUsulan = async (usulan: Usulan) => {
    try {
      setLoadingDetails(true)
      setSelectedUsulan(usulan)
      
      const response = await fetch(`/api/operator-sekolah/usulan/${usulan.id}`)
      if (response.ok) {
        const data = await response.json()
        setUsulanDetails(data.usulan)
      } else {
        // Fallback to basic data if API fails
        setUsulanDetails(usulan)
      }
      
      setIsViewModalOpen(true)
    } catch (error) {
      console.error('Error loading usulan details:', error)
      setUsulanDetails(usulan)
      setIsViewModalOpen(true)
    } finally {
      setLoadingDetails(false)
    }
  }

  // Handle edit usulan
  const handleEditUsulan = (usulan: Usulan) => {
    setSelectedUsulan(usulan)
    setFormData({
      pegawaiId: '', // Tidak bisa mengubah pegawai
      periode: usulan.tanggalUsulan.split('-')[0], // Extract year
      keterangan: usulan.keterangan || ''
    })
    setIsEditModalOpen(true)
  }

  // Handle update usulan
  const handleUpdateUsulan = async () => {
    if (!selectedUsulan) return
    
    try {
      setSubmitting(true)
      
      const response = await fetch(`/api/operator-sekolah/usulan/${selectedUsulan.id}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          periode: formData.periode,
          keterangan: formData.keterangan || null
        })
      })

      if (response.ok) {
        toast({
          title: "Berhasil!",
          description: "Usulan berhasil diperbarui",
        })
        setIsEditModalOpen(false)
        resetForm()
        setSelectedUsulan(null)
        fetchData() // Reload data
      } else {
        const errorData = await response.json()
        throw new Error(errorData.message || 'Failed to update usulan')
      }
    } catch (error) {
      console.error('Error updating usulan:', error)
      toast({
        title: "Error",
        description: error instanceof Error ? error.message : "Gagal memperbarui usulan",
        variant: "destructive"
      })
    } finally {
      setSubmitting(false)
    }
  }

  // Handle approve usulan (verifikasi)
  const handleApproveUsulan = async (usulan: Usulan) => {
    try {
      setSubmitting(true)
      
      const response = await fetch(`/api/operator-sekolah/usulan/${usulan.id}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          action: 'approve',
          notes: 'Disetujui oleh operator sekolah'
        })
      })

      if (response.ok) {
        const result = await response.json()
        toast({
          title: "Berhasil!",
          description: result.message || `Usulan ${usulan.nama} berhasil disetujui`,
        })
        fetchData() // Reload data
      } else {
        const errorData = await response.json()
        throw new Error(errorData.message || 'Failed to approve usulan')
      }
    } catch (error) {
      console.error('Error approving usulan:', error)
      toast({
        title: "Error",
        description: error instanceof Error ? error.message : "Gagal menyetujui usulan",
        variant: "destructive"
      })
    } finally {
      setSubmitting(false)
    }
  }

  // Handle reject usulan
  const handleRejectUsulan = async (usulan: Usulan) => {
    try {
      setSubmitting(true)
      
      const response = await fetch(`/api/operator-sekolah/usulan/${usulan.id}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          action: 'reject',
          notes: 'Ditolak oleh operator sekolah'
        })
      })

      if (response.ok) {
        const result = await response.json()
        toast({
          title: "Berhasil!",
          description: result.message || `Usulan ${usulan.nama} berhasil ditolak`,
        })
        fetchData() // Reload data
      } else {
        const errorData = await response.json()
        throw new Error(errorData.message || 'Failed to reject usulan')
      }
    } catch (error) {
      console.error('Error rejecting usulan:', error)
      toast({
        title: "Error",
        description: error instanceof Error ? error.message : "Gagal menolak usulan",
        variant: "destructive"
      })
    } finally {
      setSubmitting(false)
    }
  }

  // Handle return for revision
  const handleReturnForRevision = async (usulan: Usulan) => {
    try {
      setSubmitting(true)
      
      const response = await fetch(`/api/operator-sekolah/usulan/${usulan.id}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          action: 'return_for_revision',
          notes: 'Dikembalikan untuk perbaikan oleh operator sekolah'
        })
      })

      if (response.ok) {
        const result = await response.json()
        toast({
          title: "Berhasil!",
          description: result.message || `Usulan ${usulan.nama} berhasil dikembalikan untuk perbaikan`,
        })
        fetchData() // Reload data
      } else {
        const errorData = await response.json()
        throw new Error(errorData.message || 'Failed to return usulan for revision')
      }
    } catch (error) {
      console.error('Error returning usulan for revision:', error)
      toast({
        title: "Error",
        description: error instanceof Error ? error.message : "Gagal mengembalikan usulan untuk perbaikan",
        variant: "destructive"
      })
    } finally {
      setSubmitting(false)
    }
  }
  const exportToPDF = async () => {
    try {
      setExporting(true)
      
      const params = new URLSearchParams({
        format: 'pdf',
        ...(statusFilter !== "all" && { status: statusFilter })
      })
      
      const response = await fetch(`/api/operator-sekolah/usulan/export?${params}`)
      
      if (response.ok) {
        const blob = await response.blob()
        const url = window.URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = `usulan-kenaikan-pangkat-${new Date().toISOString().split('T')[0]}.pdf`
        document.body.appendChild(a)
        a.click()
        document.body.removeChild(a)
        window.URL.revokeObjectURL(url)
        
        toast({
          title: "Berhasil",
          description: "File PDF berhasil diunduh",
        })
      } else {
        throw new Error('Export failed')
      }
    } catch (error) {
      console.error('Error exporting to PDF:', error)
      toast({
        title: "Error",
        description: "Gagal mengunduh file PDF",
        variant: "destructive"
      })
    } finally {
      setExporting(false)
    }
  }

  useEffect(() => {
    fetchData()
  }, []) // fetchData will be called once on mount

  const fetchData = async () => {
    try {
      setLoading(true)
      const response = await fetch('/api/operator-sekolah/usulan')
      
      if (response.ok) {
        const data = await response.json()
        // Map API response to UI format
        const mappedUsulan = (data.usulan || []).map((item: ApiUsulanResponse) => ({
          id: item.id,
          nip: item.pegawai?.nip || '',
          nama: item.pegawai?.name || '',
          golonganAsal: item.golonganAsal || item.pegawai?.golongan || '',
          golonganTujuan: item.golonganTujuan || '',
          jabatan: item.pegawai?.jabatan || '',
          unitKerja: data.unitKerja || '',
          tanggalUsulan: item.tanggalAjukan || item.createdAt?.split('T')[0] || '',
          status: mapApiStatusToUIStatus(item.status),
          keterangan: item.keterangan || item.notes || '',
          dokumenLengkap: (item.dokumenCount || 0) > 0 && (item.dokumenDiapprove || 0) === (item.dokumenCount || 0),
          createdAt: item.tanggalAjukan || '',
          updatedAt: item.tanggalUpdate || ''
        }))
        setUsulanData(mappedUsulan)
      } else {
        // Gunakan mock data jika API tidak tersedia
        console.log('API not available, using mock data')
        setUsulanData(mockUsulanData)
        toast({
          title: "Info",
          description: "Menggunakan data demo karena API belum tersedia",
          variant: "default"
        })
      }
    } catch (error) {
      console.error("Error fetching usulan data:", error)
      // Gunakan mock data jika terjadi error
      setUsulanData(mockUsulanData)
      toast({
        title: "Info",
        description: "Menggunakan data demo karena terjadi kesalahan",
        variant: "default"
      })
    } finally {
      setLoading(false)
    }
  }

  // Map API status to UI status
  const mapApiStatusToUIStatus = (apiStatus: string) => {
    const statusMap: Record<string, string> = {
      'DRAFT': 'menunggu_verifikasi',
      'DIAJUKAN': 'menunggu_verifikasi',
      'DIPROSES_OPERATOR': 'sedang_diproses',
      'DISETUJUI_OPERATOR': 'sedang_diproses',
      'DIPROSES_ADMIN': 'sedang_diproses',
      'SELESAI': 'disetujui',
      'DITOLAK': 'ditolak',
      'DIKEMBALIKAN_OPERATOR': 'butuh_perbaikan',
      'DIKEMBALIKAN_ADMIN': 'butuh_perbaikan',
      'MENUNGGU_VERIFIKASI_DINAS': 'menunggu_verifikasi',
      'MENUNGGU_VERIFIKASI_SEKOLAH': 'menunggu_verifikasi',
      'PERLU_PERBAIKAN_DARI_DINAS': 'butuh_perbaikan',
      'PERLU_PERBAIKAN_DARI_SEKOLAH': 'butuh_perbaikan'
    }
    return statusMap[apiStatus] || 'menunggu_verifikasi'
  }

  useEffect(() => {
    let filtered = usulanData

    // Filter berdasarkan pencarian
    if (searchQuery) {
      filtered = filtered.filter(
        (usulan) =>
          usulan.nama.toLowerCase().includes(searchQuery.toLowerCase()) ||
          usulan.nip.includes(searchQuery) ||
          usulan.unitKerja.toLowerCase().includes(searchQuery.toLowerCase())
      )
    }

    // Filter berdasarkan status
    if (statusFilter && statusFilter !== "all") {
      filtered = filtered.filter((usulan) => usulan.status === statusFilter)
    }

    setFilteredData(filtered)
  }, [usulanData, searchQuery, statusFilter])

  const handleVerifyUsulan = async (id: string) => {
    try {
      const response = await fetch(`/api/operator-sekolah/usulan/${id}/verify`, {
        method: 'POST',
      })

      if (response.ok) {
        toast({
          title: "Sukses",
          description: "Usulan berhasil diverifikasi",
        })
        // Refresh data
        fetchData()
      } else {
        toast({
          title: "Error",
          description: "Gagal memverifikasi usulan",
          variant: "destructive"
        })
      }
    } catch (error) {
      console.error("Error verifying usulan:", error)
      toast({
        title: "Error",
        description: "Terjadi kesalahan saat memverifikasi usulan",
        variant: "destructive"
      })
    }
  }

  const getStatsData = () => {
    const stats = {
      total: usulanData.length,
      menunggu: usulanData.filter(u => u.status === 'menunggu_verifikasi').length,
      diproses: usulanData.filter(u => u.status === 'sedang_diproses').length,
      disetujui: usulanData.filter(u => u.status === 'disetujui').length,
      ditolak: usulanData.filter(u => u.status === 'ditolak').length,
      perbaikan: usulanData.filter(u => u.status === 'butuh_perbaikan').length
    }
    return stats
  }

  const stats = getStatsData()

  if (loading) {
    return (
      <DashboardLayout userType="operator-sekolah">
        <div className="flex items-center justify-center h-64">
          <div className="text-center">
            <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-primary mx-auto mb-4"></div>
            <p>Memuat data usulan...</p>
          </div>
        </div>
      </DashboardLayout>
    )
  }

  return (
    <DashboardLayout userType="operator-sekolah">
      <div className="space-y-6">
        {/* Header */}
        <div className="flex items-center justify-between">
          <div>
            <h1 className="text-3xl font-bold tracking-tight">Usulan Kenaikan Pangkat</h1>
            <p className="text-muted-foreground">
              Kelola dan verifikasi usulan kenaikan pangkat pegawai
            </p>
          </div>
          <div className="flex items-center gap-4">
            <Button 
              onClick={exportToPDF} 
              variant="outline" 
              className="flex items-center gap-2"
              disabled={exporting}
            >
              {exporting ? <Loader2 className="h-4 w-4 animate-spin" /> : <Download className="h-4 w-4" />}
              Export PDF
            </Button>
            <Button 
              onClick={exportToExcel} 
              variant="outline" 
              className="flex items-center gap-2"
              disabled={exporting}
            >
              {exporting ? <Loader2 className="h-4 w-4 animate-spin" /> : <FileSpreadsheet className="h-4 w-4" />}
              Export Excel
            </Button>
            <Button 
              className="flex items-center gap-2" 
              onClick={() => {
                setIsAddModalOpen(true)
                loadPegawaiOptions()
              }}
            >
              <Plus className="h-4 w-4" />
              Tambah Usulan
            </Button>
          </div>
        </div>

        {/* Statistics Cards */}
        <div className="grid gap-4 md:grid-cols-3 lg:grid-cols-6">
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Total Usulan</CardTitle>
              <FileText className="h-4 w-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold">{stats.total}</div>
            </CardContent>
          </Card>
          
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Menunggu</CardTitle>
              <Clock className="h-4 w-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-orange-600">{stats.menunggu}</div>
            </CardContent>
          </Card>
          
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Diproses</CardTitle>
              <Clock className="h-4 w-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-blue-600">{stats.diproses}</div>
            </CardContent>
          </Card>
          
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Disetujui</CardTitle>
              <CheckCircle className="h-4 w-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-green-600">{stats.disetujui}</div>
            </CardContent>
          </Card>
          
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Ditolak</CardTitle>
              <XCircle className="h-4 w-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-red-600">{stats.ditolak}</div>
            </CardContent>
          </Card>
          
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
              <CardTitle className="text-sm font-medium">Butuh Perbaikan</CardTitle>
              <AlertTriangle className="h-4 w-4 text-muted-foreground" />
            </CardHeader>
            <CardContent>
              <div className="text-2xl font-bold text-yellow-600">{stats.perbaikan}</div>
            </CardContent>
          </Card>
        </div>

        {/* Search and Filter */}
        <Card>
          <CardContent className="p-6">
            <div className="flex flex-col sm:flex-row gap-4">
              <div className="flex-1">
                <div className="relative">
                  <Search className="absolute left-3 top-3 h-4 w-4 text-muted-foreground" />
                  <Input
                    placeholder="Cari berdasarkan nama, NIP, atau unit kerja..."
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                    className="pl-10"
                  />
                </div>
              </div>
              <div className="flex gap-2">
                <Select value={statusFilter} onValueChange={setStatusFilter}>
                  <SelectTrigger className="w-[200px]">
                    <Filter className="h-4 w-4 mr-2" />
                    <SelectValue placeholder="Filter Status" />
                  </SelectTrigger>
                  <SelectContent>
                    {statusOptions.map((option) => (
                      <SelectItem key={option.value} value={option.value}>
                        {option.label}
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
            </div>
          </CardContent>
        </Card>

        {/* Data Table */}
        <Card>
          <CardHeader>
            <CardTitle>Daftar Usulan ({filteredData.length})</CardTitle>
            <CardDescription>
              {statusFilter === "all" 
                ? "Menampilkan semua usulan kenaikan pangkat"
                : `Menampilkan usulan dengan status: ${statusOptions.find(s => s.value === statusFilter)?.label}`
              }
            </CardDescription>
          </CardHeader>
          <CardContent>
            <div className="rounded-md border">
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead>NIP / Nama</TableHead>
                    <TableHead>Jabatan</TableHead>
                    <TableHead>Unit Kerja</TableHead>
                    <TableHead>Kenaikan Pangkat</TableHead>
                    <TableHead>Tanggal Usulan</TableHead>
                    <TableHead>Status</TableHead>
                    <TableHead>Aksi</TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {filteredData.length > 0 ? (
                    filteredData.map((usulan) => (
                      <TableRow key={usulan.id}>
                        <TableCell>
                          <div>
                            <div className="font-medium">{usulan.nama}</div>
                            <div className="text-sm text-muted-foreground font-mono">{usulan.nip}</div>
                          </div>
                        </TableCell>
                        <TableCell>{usulan.jabatan}</TableCell>
                        <TableCell>
                          <div className="max-w-[200px] truncate" title={usulan.unitKerja}>
                            {usulan.unitKerja}
                          </div>
                        </TableCell>
                        <TableCell>
                          <div className="text-sm">
                            <span className="font-medium">{usulan.golonganAsal}</span>
                            <span className="mx-2">→</span>
                            <span className="font-medium text-green-600">{usulan.golonganTujuan}</span>
                          </div>
                        </TableCell>
                        <TableCell>
                          {new Date(usulan.tanggalUsulan).toLocaleDateString('id-ID')}
                        </TableCell>
                        <TableCell>
                          {getStatusBadge(usulan.status)}
                          {usulan.keterangan && (
                            <div className="text-xs text-muted-foreground mt-1 max-w-[150px] truncate" title={usulan.keterangan}>
                              {usulan.keterangan}
                            </div>
                          )}
                        </TableCell>
                        <TableCell>
                          <div className="flex items-center gap-2">
                            <Button 
                              size="sm" 
                              variant="outline"
                              onClick={() => handleViewUsulan(usulan)}
                              title="Lihat Detail"
                            >
                              <Eye className="h-4 w-4" />
                            </Button>
                            
                            {usulan.status === 'MENUNGGU_VERIFIKASI_SEKOLAH' && (
                              <>
                                <Button 
                                  size="sm" 
                                  onClick={() => handleApproveUsulan(usulan)}
                                  className="bg-green-600 hover:bg-green-700"
                                  title="Setujui Usulan"
                                  disabled={submitting}
                                >
                                  {submitting ? <Loader2 className="h-4 w-4 animate-spin" /> : <CheckCircle className="h-4 w-4" />}
                                </Button>
                                <Button 
                                  size="sm" 
                                  onClick={() => handleRejectUsulan(usulan)}
                                  className="bg-red-600 hover:bg-red-700"
                                  title="Tolak Usulan"
                                  disabled={submitting}
                                >
                                  {submitting ? <Loader2 className="h-4 w-4 animate-spin" /> : <X className="h-4 w-4" />}
                                </Button>
                                <Button 
                                  size="sm" 
                                  onClick={() => handleReturnForRevision(usulan)}
                                  className="bg-orange-600 hover:bg-orange-700"
                                  title="Kembalikan untuk Perbaikan"
                                  disabled={submitting}
                                >
                                  {submitting ? <Loader2 className="h-4 w-4 animate-spin" /> : <ArrowLeft className="h-4 w-4" />}
                                </Button>
                              </>
                            )}
                            
                            <Button 
                              size="sm" 
                              variant="outline"
                              onClick={() => handleEditUsulan(usulan)}
                              title="Edit Usulan"
                              disabled={!['DRAFT', 'PERLU_PERBAIKAN_DARI_SEKOLAH', 'DIKEMBALIKAN_OPERATOR'].includes(usulan.status)}
                            >
                              <Edit className="h-4 w-4" />
                            </Button>
                          </div>
                        </TableCell>
                      </TableRow>
                    ))
                  ) : (
                    <TableRow>
                      <TableCell colSpan={7} className="text-center py-8">
                        <div className="text-muted-foreground">
                          {searchQuery || statusFilter !== "all" 
                            ? "Tidak ada usulan yang sesuai dengan filter" 
                            : "Belum ada data usulan"
                          }
                        </div>
                      </TableCell>
                    </TableRow>
                  )}
                </TableBody>
              </Table>
            </div>
          </CardContent>
        </Card>

        {/* Modal Tambah Usulan */}
        <Dialog open={isAddModalOpen} onOpenChange={setIsAddModalOpen}>
          <DialogContent className="max-w-2xl">
            <DialogHeader>
              <DialogTitle>Tambah Usulan Kenaikan Pangkat</DialogTitle>
              <DialogDescription>
                Buat usulan kenaikan pangkat untuk pegawai di unit kerja Anda
              </DialogDescription>
            </DialogHeader>
            <div className="grid gap-4">
              <div>
                <Label htmlFor="pegawai">Pilih Pegawai</Label>
                <Select 
                  value={formData.pegawaiId} 
                  onValueChange={(value) => setFormData({ ...formData, pegawaiId: value })}
                >
                  <SelectTrigger>
                    <SelectValue placeholder={loadingPegawai ? "Memuat data pegawai..." : "Pilih pegawai"} />
                  </SelectTrigger>
                  <SelectContent>
                    {pegawaiOptions.map((pegawai) => (
                      <SelectItem key={pegawai.id} value={pegawai.id}>
                        <div className="flex flex-col">
                          <span className="font-medium">{pegawai.nama}</span>
                          <span className="text-sm text-muted-foreground">
                            {pegawai.nip} - {pegawai.jabatan} - {pegawai.golongan}
                          </span>
                        </div>
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
              <div>
                <Label htmlFor="periode">Periode</Label>
                <Input
                  id="periode"
                  value={formData.periode}
                  onChange={(e) => setFormData({ ...formData, periode: e.target.value })}
                  placeholder="Contoh: Agustus 2025"
                />
              </div>
              <div>
                <Label htmlFor="keterangan">Keterangan (Opsional)</Label>
                <Textarea
                  id="keterangan"
                  value={formData.keterangan}
                  onChange={(e) => setFormData({ ...formData, keterangan: e.target.value })}
                  placeholder="Masukkan keterangan tambahan..."
                  rows={3}
                />
              </div>
              
              {/* Required Cover Letter Fields */}
              <div className="border-t pt-4">
                <h4 className="font-medium mb-3 text-sm text-gray-700">Surat Pengantar (Wajib)</h4>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <Label htmlFor="nomorSuratPengantar">Nomor Surat Pengantar *</Label>
                    <Input
                      id="nomorSuratPengantar"
                      value={formData.nomorSuratPengantar}
                      onChange={(e) => setFormData({ ...formData, nomorSuratPengantar: e.target.value })}
                      placeholder="Contoh: 001/SP/2025"
                      required
                    />
                  </div>
                  <div>
                    <Label htmlFor="tanggalSurat">Tanggal Surat *</Label>
                    <Input
                      id="tanggalSurat"
                      type="date"
                      value={formData.tanggalSurat}
                      onChange={(e) => setFormData({ ...formData, tanggalSurat: e.target.value })}
                      required
                    />
                  </div>
                </div>
                <div className="mt-4">
                  <Label htmlFor="fileSuratPengantar">Upload Surat Pengantar (Opsional)</Label>
                  <Input
                    id="fileSuratPengantar"
                    type="file"
                    accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                    onChange={(e) => {
                      const file = e.target.files?.[0]
                      setFormData({ ...formData, fileSuratPengantar: file || null })
                    }}
                    className="mt-1"
                  />
                  <p className="text-xs text-gray-500 mt-1">
                    Format: PDF, DOC, DOCX, JPG, PNG (Max. 5MB)
                  </p>
                </div>
              </div>
            </div>
            <DialogFooter>
              <Button variant="outline" onClick={() => setIsAddModalOpen(false)}>
                Batal
              </Button>
              <Button onClick={handleAddUsulan} disabled={submitting || !formData.pegawaiId}>
                {submitting ? (
                  <>
                    <Loader2 className="h-4 w-4 animate-spin mr-2" />
                    Menyimpan...
                  </>
                ) : (
                  "Buat Usulan"
                )}
              </Button>
            </DialogFooter>
          </DialogContent>
        </Dialog>

        {/* Modal View Usulan */}
        <Dialog open={isViewModalOpen} onOpenChange={setIsViewModalOpen}>
          <DialogContent className="max-w-5xl w-[95vw] max-h-[90vh] flex flex-col p-0 bg-white">
            <DialogHeader className="flex-shrink-0 px-6 py-6 border-b border-gray-200 bg-gray-50">
              <div className="flex items-center justify-between">
                <div>
                  <DialogTitle className="text-xl font-bold text-gray-900">
                    Detail Usulan Kenaikan Pangkat
                  </DialogTitle>
                  <DialogDescription className="text-sm text-gray-600 mt-2">
                    Informasi lengkap usulan untuk <span className="font-medium text-gray-800">{selectedUsulan?.nama}</span>
                  </DialogDescription>
                </div>
                <Button 
                  variant="ghost" 
                  size="icon"
                  onClick={() => setIsViewModalOpen(false)}
                  className="h-10 w-10 rounded-full hover:bg-gray-200 transition-colors"
                >
                  <X className="h-5 w-5" />
                </Button>
              </div>
            </DialogHeader>
            
            <div className="flex-1 overflow-y-auto px-6 py-6 bg-white">
              {loadingDetails ? (
                <div className="flex items-center justify-center py-20">
                  <div className="text-center">
                    <Loader2 className="h-10 w-10 animate-spin mx-auto mb-4 text-blue-600" />
                    <span className="text-base text-gray-600">Memuat detail usulan...</span>
                  </div>
                </div>
              ) : usulanDetails ? (
                <div className="space-y-8">
                  {/* Data Pegawai & Usulan - Grid Layout */}
                  <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    {/* Data Pegawai */}
                    <div className="bg-gray-50 rounded-lg p-6 border border-gray-200">
                      <h4 className="font-bold text-lg text-gray-900 mb-4 flex items-center">
                        <User className="h-5 w-5 mr-2 text-blue-600" />
                        Data Pegawai
                      </h4>
                      <div className="space-y-4">
                        <div>
                          <Label className="text-sm font-medium text-gray-700 mb-1 block">NIP</Label>
                          <div className="bg-white p-3 rounded-md border border-gray-300 font-mono text-sm text-gray-900">
                            {usulanDetails.pegawai?.nip || selectedUsulan?.nip}
                          </div>
                        </div>
                        <div>
                          <Label className="text-sm font-medium text-gray-700 mb-1 block">Nama Lengkap</Label>
                          <div className="bg-white p-3 rounded-md border border-gray-300 text-sm font-medium text-gray-900">
                            {usulanDetails.pegawai?.name || selectedUsulan?.nama}
                          </div>
                        </div>
                        <div>
                          <Label className="text-sm font-medium text-gray-700 mb-1 block">Jabatan</Label>
                          <div className="bg-white p-3 rounded-md border border-gray-300 text-sm text-gray-900">
                            {usulanDetails.pegawai?.jabatan || selectedUsulan?.jabatan}
                          </div>
                        </div>
                        <div>
                          <Label className="text-sm font-medium text-gray-700 mb-1 block">Unit Kerja</Label>
                          <div className="bg-white p-3 rounded-md border border-gray-300 text-sm text-gray-900">
                            {usulanDetails.pegawai?.unitKerja || selectedUsulan?.unitKerja}
                          </div>
                        </div>
                      </div>
                    </div>

                    {/* Data Usulan */}
                    <div className="bg-blue-50 rounded-lg p-6 border border-blue-200">
                      <h4 className="font-bold text-lg text-gray-900 mb-4 flex items-center">
                        <FileText className="h-5 w-5 mr-2 text-blue-600" />
                        Data Usulan
                      </h4>
                      <div className="space-y-4">
                        <div>
                          <Label className="text-sm font-medium text-gray-700 mb-1 block">Kenaikan Pangkat</Label>
                          <div className="bg-white p-3 rounded-md border border-blue-300 text-sm">
                            <span className="font-semibold text-blue-700">
                              {usulanDetails.golonganAsal || "IV/a"}
                            </span>
                            <span className="mx-3 text-gray-500">→</span>
                            <span className="font-semibold text-green-700">
                              {usulanDetails.golonganTujuan || "IV/b"}
                            </span>
                          </div>
                        </div>
                        <div>
                          <Label className="text-sm font-medium text-gray-700 mb-1 block">Periode</Label>
                          <div className="bg-white p-3 rounded-md border border-blue-300 text-sm text-gray-900">
                            {usulanDetails.periode || selectedUsulan?.tanggalUsulan}
                          </div>
                        </div>
                        <div>
                          <Label className="text-sm font-medium text-gray-700 mb-1 block">Status</Label>
                          <div className="bg-white p-3 rounded-md border border-blue-300">
                            {getStatusBadge(selectedUsulan?.status || '')}
                          </div>
                        </div>
                        <div>
                          <Label className="text-sm font-medium text-gray-700 mb-1 block">Tanggal Diajukan</Label>
                          <div className="bg-white p-3 rounded-md border border-blue-300 text-sm text-gray-900">
                            {usulanDetails.tanggalAjukan || selectedUsulan?.tanggalUsulan}
                          </div>
                        </div>
                        {usulanDetails.keterangan && (
                          <div>
                            <Label className="text-sm font-medium text-gray-700 mb-1 block">Keterangan</Label>
                            <div className="bg-yellow-50 p-3 rounded-md border border-yellow-300 text-sm text-gray-900">
                              {usulanDetails.keterangan}
                            </div>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>

                  {/* Status Dokumen */}
                  <div className="bg-white border border-gray-200 rounded-lg p-6">
                    <h4 className="font-bold text-lg text-gray-900 mb-4 flex items-center">
                      <FileText className="h-5 w-5 mr-2 text-green-600" />
                      Status Dokumen
                    </h4>
                    
                    {/* Informasi Penting */}
                    <div className="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 p-5 rounded-lg mb-6">
                      <div className="flex items-start gap-4">
                        <div className="bg-blue-100 p-2 rounded-full">
                          <AlertTriangle className="h-6 w-6 text-blue-600" />
                        </div>
                        <div className="flex-1">
                          <h5 className="font-semibold text-blue-900 text-base mb-2">Informasi Penting</h5>
                          <p className="text-sm text-blue-800 leading-relaxed">
                            Setelah usulan dibuat, pegawai <strong className="text-blue-900">{selectedUsulan?.nama}</strong> harus login ke akun mereka 
                            untuk mengupload dokumen-dokumen yang diperlukan. Usulan akan diproses setelah semua dokumen lengkap dan terverifikasi.
                          </p>
                        </div>
                      </div>
                    </div>
                    
                    {/* Daftar Dokumen */}
                    {usulanDetails.documents && usulanDetails.documents.length > 0 ? (
                      <div className="space-y-4">
                        <div className="flex items-center justify-between">
                          <p className="text-base font-medium text-gray-900">
                            Dokumen yang sudah diupload
                          </p>
                          <Badge variant="secondary" className="px-3 py-1">
                            {usulanDetails.documents.length} dokumen
                          </Badge>
                        </div>
                        <div className="grid gap-4 max-h-80 overflow-y-auto pr-2">
                          {usulanDetails.documents.map((doc: UsulanDocument) => (
                            <div key={doc.id} className="bg-gray-50 border border-gray-200 rounded-lg p-4 hover:shadow-sm transition-shadow">
                              <div className="flex items-center justify-between">
                                <div className="flex items-center gap-3 flex-1 min-w-0">
                                  <div className="bg-blue-100 p-2 rounded-lg">
                                    <FileText className="h-5 w-5 text-blue-600" />
                                  </div>
                                  <div className="min-w-0 flex-1">
                                    <p className="font-medium text-sm text-gray-900 truncate mb-1">
                                      {doc.name}
                                    </p>
                                    {doc.fileName && (
                                      <p className="text-xs text-gray-500 truncate">
                                        File: {doc.fileName}
                                      </p>
                                    )}
                                    <p className="text-xs text-gray-500 mt-1">
                                      Upload: {doc.uploadedAt ? format(new Date(doc.uploadedAt), 'dd MMM yyyy, HH:mm') : 'Tanggal tidak tersedia'}
                                    </p>
                                  </div>
                                </div>
                                <div className="flex items-center gap-2 ml-3">
                                  <Badge 
                                    variant={
                                      doc.status === 'APPROVED' ? 'default' :
                                      doc.status === 'PENDING' ? 'secondary' :
                                      doc.status === 'REJECTED' ? 'destructive' : 'outline'
                                    }
                                    className="text-xs"
                                  >
                                    {doc.status === 'APPROVED' ? 'Disetujui' :
                                     doc.status === 'PENDING' ? 'Pending' :
                                     doc.status === 'REJECTED' ? 'Ditolak' : doc.status}
                                  </Badge>
                                  {doc.fileUrl && (
                                    <Button
                                      variant="outline"
                                      size="sm"
                                      className="h-8 w-8 p-0"
                                      onClick={() => window.open(doc.fileUrl, '_blank')}
                                    >
                                      <ExternalLink className="h-4 w-4" />
                                    </Button>
                                  )}
                                </div>
                              </div>
                              {doc.notes && (
                                <div className="mt-3 p-3 bg-yellow-50 border border-yellow-200 rounded-md">
                                  <p className="text-xs text-yellow-800">
                                    <strong>Catatan:</strong> {doc.notes}
                                  </p>
                                </div>
                              )}
                            </div>
                          ))}
                        </div>
                      </div>
                    ) : (
                      <div className="text-center py-12">
                        <div className="bg-gray-100 p-4 rounded-full w-16 h-16 mx-auto mb-4 flex items-center justify-center">
                          <FileText className="h-8 w-8 text-gray-400" />
                        </div>
                        <p className="text-gray-600 font-medium mb-2">Belum ada dokumen</p>
                        <p className="text-sm text-gray-500">
                          Pegawai belum mengupload dokumen untuk usulan ini
                        </p>
                      </div>
                    )}
                  </div>
                                    <p className="text-xs text-gray-500 truncate">{doc.fileName}</p>
                                  )}
                                </div>
                              </div>
                              <Badge 
                                variant={doc.status === 'DISETUJUI' ? 'default' : 'secondary'}
                                className={`flex-shrink-0 ml-2 ${
                                  doc.status === 'DISETUJUI' ? 'bg-green-100 text-green-800' :
                                  doc.status === 'DITOLAK' ? 'bg-red-100 text-red-800' :
                                  doc.status === 'PERLU_PERBAIKAN' ? 'bg-orange-100 text-orange-800' :
                                  'bg-gray-100 text-gray-800'
                                }`}
                              >
                                {doc.status === 'DISETUJUI' ? 'Disetujui' : 
                                 doc.status === 'DITOLAK' ? 'Ditolak' : 
                                 doc.status === 'PERLU_PERBAIKAN' ? 'Perlu Perbaikan' : 'Menunggu'}
                              </Badge>
                            </div>
                          ))}
                        </div>
                      </div>
                    ) : (
                      <div className="text-center py-8 border-2 border-dashed border-gray-200 rounded-lg">
                        <FileText className="h-12 w-12 mx-auto mb-3 text-gray-400" />
                        <p className="font-medium text-gray-600 mb-1">Belum ada dokumen yang diupload</p>
                        <p className="text-sm text-gray-500">Pegawai perlu login untuk mengupload dokumen</p>
                      </div>
                    )}
                  </div>
                </div>
              ) : (
                <div className="text-center py-8">
                  <p className="text-gray-500">Data tidak dapat dimuat</p>
                </div>
              )}
            </div>
            
            <DialogFooter className="flex-shrink-0 border-t border-gray-200 bg-gray-50 px-6 py-4">
              <div className="flex flex-col sm:flex-row gap-3 w-full sm:w-auto sm:ml-auto">
                <Button 
                  variant="outline" 
                  onClick={() => setIsViewModalOpen(false)} 
                  className="w-full sm:w-auto px-6 py-2 border-gray-300 hover:bg-gray-50"
                >
                  Tutup
                </Button>
                {selectedUsulan && ['menunggu_verifikasi', 'butuh_perbaikan'].includes(selectedUsulan.status) && (
                  <Button 
                    onClick={() => {
                      setIsViewModalOpen(false)
                      handleEditUsulan(selectedUsulan)
                    }}
                    className="w-full sm:w-auto px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white"
                  >
                    Edit Usulan
                  </Button>
                )}
              </div>
            </DialogFooter>
          </DialogContent>
        </Dialog>

        {/* Modal Edit Usulan */}
        <Dialog open={isEditModalOpen} onOpenChange={setIsEditModalOpen}>
          <DialogContent className="max-w-2xl">
            <DialogHeader>
              <DialogTitle>Edit Usulan Kenaikan Pangkat</DialogTitle>
              <DialogDescription>
                Edit informasi usulan untuk {selectedUsulan?.nama}
              </DialogDescription>
            </DialogHeader>
            <div className="grid gap-4">
              <div>
                <Label className="text-sm font-medium text-gray-500">Pegawai</Label>
                <p className="text-sm">{selectedUsulan?.nama} ({selectedUsulan?.nip})</p>
                <p className="text-xs text-muted-foreground">Pegawai tidak dapat diubah</p>
              </div>
              <div>
                <Label htmlFor="edit-periode">Periode</Label>
                <Input
                  id="edit-periode"
                  value={formData.periode}
                  onChange={(e) => setFormData({ ...formData, periode: e.target.value })}
                  placeholder="Contoh: Agustus 2025"
                />
              </div>
              <div>
                <Label htmlFor="edit-keterangan">Keterangan</Label>
                <Textarea
                  id="edit-keterangan"
                  value={formData.keterangan}
                  onChange={(e) => setFormData({ ...formData, keterangan: e.target.value })}
                  placeholder="Masukkan keterangan tambahan..."
                  rows={3}
                />
              </div>
            </div>
            <DialogFooter>
              <Button variant="outline" onClick={() => setIsEditModalOpen(false)}>
                Batal
              </Button>
              <Button onClick={handleUpdateUsulan} disabled={submitting}>
                {submitting ? (
                  <>
                    <Loader2 className="h-4 w-4 animate-spin mr-2" />
                    Menyimpan...
                  </>
                ) : (
                  "Simpan Perubahan"
                )}
              </Button>
            </DialogFooter>
          </DialogContent>
        </Dialog>
      </div>
    </DashboardLayout>
  )
}
