# Database Configuration
# Use local/non-production credentials. Do not commit real passwords.
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/propangkat_db"

# NextAuth Configuration
NEXTAUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Iron Session Configuration
# Minimum 32 characters, unique per environment.
SECRET_COOKIE_PASSWORD="CHANGE_ME_MIN_32_CHARACTERS_SESSION_SECRET"

# Application Configuration
APP_ENV="development"
APP_URL="http://localhost:3000"

# File Upload Configuration
UPLOAD_MAX_SIZE="10485760"
UPLOAD_ALLOWED_TYPES="application/pdf,image/jpeg,image/jpg,image/png"
