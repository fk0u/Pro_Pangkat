generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  nip                String              @unique
  name               String
  email              String?             @unique
  password           String
  role               Role                @default(PEGAWAI)
  mustChangePassword Boolean             @default(true)
  totpSecret         String?             // Added for 2FA validation
  isTwoFactorEnabled Boolean             @default(false)
  golongan           String?
  tmtGolongan        DateTime?
  tmtJabatan         DateTime?
  jabatan            String?
  jenisJabatan       String?
  unitKerjaId        String?
  wilayah            Wilayah?
  phone              String?
  address            String?
  profilePictureUrl  String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  activityLogs       ActivityLog[]
  notifications      Notification[]
  verifiedProposals  PromotionProposal[] @relation("OperatorVerifications")
  proposals          PromotionProposal[] @relation("PegawaiProposals")
  unitKerja          UnitKerja?          @relation(fields: [unitKerjaId], references: [id])
}

model UnitKerja {
  id        String   @id @default(cuid())
  nama      String   @unique
  npsn      String?  @unique
  jenjang   String
  alamat    String?
  kecamatan String?
  wilayah   Wilayah
  status    String   @default("Aktif")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pegawai   User[]

  @@index([wilayah])
  @@index([jenjang])
}

model PromotionProposal {
  id                  String             @id @default(cuid())
  periode             String
  status              StatusProposal     @default(DRAFT)
  notes               String?
  nomorSuratPengantar String?
  tanggalSurat        DateTime?
  fileSuratPengantar  String?
  pegawaiId           String
  operatorId          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  operator            User?              @relation("OperatorVerifications", fields: [operatorId], references: [id])
  pegawai             User               @relation("PegawaiProposals", fields: [pegawaiId], references: [id])
  documents           ProposalDocument[]
}

model DocumentRequirement {
  id          String                @id @default(cuid())
  code        String                @unique
  name        String
  description String?
  isRequired  Boolean               @default(true)
  hasSimASN   Boolean               @default(false)
  detailInfo  DetailedDocumentInfo?
  proposals   ProposalDocument[]
}

model ProposalDocument {
  id                    String              @id @default(cuid())
  proposalId            String
  documentRequirementId String
  fileUrl               String
  fileName              String
  fileSize              Int
  status                StatusDokumen       @default(MENUNGGU_VERIFIKASI)
  notes                 String?
  uploadedAt            DateTime            @default(now())
  documentRequirement   DocumentRequirement @relation(fields: [documentRequirementId], references: [id])
  proposal              PromotionProposal   @relation(fields: [proposalId], references: [id])

  @@unique([proposalId, documentRequirementId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   Json?
  diff      Json?
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Timeline {
  id          String   @id @default(cuid())
  title       String
  description String?
  jabatanType String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  priority    Int      @default(1)
  wilayah     Wilayah?
  createdBy   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DetailedDocumentInfo {
  id             String              @id @default(cuid())
  documentReqId  String              @unique
  purpose        String?
  obtainMethod   String?
  validityPeriod String?
  legalBasis     String?
  templateUrl    String?
  sampleUrl      String?
  requirements   Json?
  fillTips       String?
  commonMistakes String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  documentReq    DocumentRequirement @relation(fields: [documentReqId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String   @default("info")
  userId      String?
  userRole    Role?
  isRead      Boolean  @default(false)
  actionUrl   String?
  actionLabel String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
}

enum Role {
  PEGAWAI
  OPERATOR
  ADMIN
  OPERATOR_SEKOLAH
  OPERATOR_UNIT_KERJA
}

enum StatusDokumen {
  MENUNGGU_VERIFIKASI
  PERLU_PERBAIKAN
  DISETUJUI
  DITOLAK
}

enum StatusProposal {
  DRAFT
  DIAJUKAN
  DIPROSES_OPERATOR
  DIKEMBALIKAN_OPERATOR
  DISETUJUI_OPERATOR
  DITERUSKAN_KE_PUSAT
  DIPROSES_ADMIN
  DIKEMBALIKAN_ADMIN
  SELESAI
  DITOLAK
  DITARIK
  MENUNGGU_VERIFIKASI_DINAS
  MENUNGGU_VERIFIKASI_SEKOLAH
  PERLU_PERBAIKAN_DARI_DINAS
  PERLU_PERBAIKAN_DARI_SEKOLAH
  DITOLAK_SEKOLAH
  DITOLAK_DINAS
  DITOLAK_ADMIN
}

enum Wilayah {
  BALIKPAPAN_PPU
  KUTIM_BONTANG
  KUKAR
  KUBAR_MAHULU
  PASER
  BERAU
  SAMARINDA
}
